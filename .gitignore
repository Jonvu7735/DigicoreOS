# Rust / Cargo build output
/target/
**/*.rs.bk

# These should stay tracked (do NOT ignore):
#   Cargo.lock      – pinned for reproducible builds (workspace with binaries)
#   rust-toolchain.toml

# Local environment / secrets (SECURITY.md: never commit secrets)
.env
.env.*
*.local
# Dev-only RS256 JWT keys generated by scripts/gen-dev-jwt-keys.sh
/.dev/

# Editor / OS noise
/.idea/
/.vscode/
*.swp
.DS_Store
