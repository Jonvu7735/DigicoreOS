{
  "name": "@digicore/api-client",
  "version": "1.0.0",
  "private": true,
  "description": "Typed client for the DigicoreOS platform API, generated from docs/openapi.yaml.",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../docs/openapi.yaml -o ./src/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.0"
  }
}
